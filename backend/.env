# Application
APP_NAME=Incident Management System
DEBUG=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ims
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=ims_signals

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Ingestion settings
SIGNAL_QUEUE_MAXSIZE=50000
WORKER_CONCURRENCY=10
DEBOUNCE_WINDOW_SECONDS=10
DEBOUNCE_THRESHOLD=100
RATE_LIMIT=500/minute

# Observability
METRICS_INTERVAL_SECONDS=5
